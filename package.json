{
  "name": "golfreplay",
  "version": "1.0.0",
  "description": "A web app for recording your golf swing and instantly replaying it — first at normal speed, then in slow motion.",
  "main": "app.js",
  "scripts": {
    "lint": "biome lint app.js style.css",
    "format": "biome format --write app.js style.css",
    "check": "biome check --write app.js style.css",
    "test": "playwright test --pass-with-no-tests",
    "test:ui": "playwright test --ui",
    "test:slow": "SLOWMO=500 playwright test --headed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/larsselstad/golfreplay.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/larsselstad/golfreplay/issues"
  },
  "homepage": "https://github.com/larsselstad/golfreplay#readme",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.60.0",
    "serve": "^14.2.6"
  }
}
